[Unit]
Description=TUFF-Xwin recovery watchdog
PartOf=tuff-xwin.target

[Service]
Type=simple
Environment=PATH=%h/.local/share/tuff-xwin/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=-%h/.config/tuff-xwin/session.env
ExecStart=/usr/bin/env watchdog --serve-ipc $TUFF_XWIN_WATCHDOG_ARGS
Restart=on-failure
RestartSec=1

[Install]
WantedBy=tuff-xwin.target
