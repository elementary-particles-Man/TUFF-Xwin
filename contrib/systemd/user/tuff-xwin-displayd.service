[Unit]
Description=TUFF-Xwin display broker
PartOf=tuff-xwin.target

[Service]
Type=simple
EnvironmentFile=%h/.config/tuff-xwin/session.env
ExecStart=${TUFF_XWIN_PREFIX}/bin/displayd $TUFF_XWIN_DISPLAYD_ARGS --session-instance-id ${TUFF_XWIN_SESSION_INSTANCE_ID}
Restart=on-failure
RestartSec=1

[Install]
WantedBy=tuff-xwin.target
