{
  "id": "demo-wayland-compd-recovery",
  "display_name": "Demo Native Wayland Compd Recovery",
  "protocol": "wayland-native",
  "summary": "sessiond/watchdog から compd broker を restart し、displayd/waylandd snapshot で scene rebuild と selection handoff を行う。lock UI は broker-owned lockd に任せ、shell/panel/settings-daemon/applet を載せる Wayland native demo profile。",
  "degraded_profile_id": null,
  "broker_services": [
    "displayd",
    "sessiond",
    "watchdog",
    "waylandd",
    "lockd"
  ],
  "session_components": [
    {
      "id": "broker-compd",
      "role": "window-manager",
      "command": ["compd", "--serve-ipc", "--fail-resume"],
      "critical": true,
      "launcher": "repo-binary"
    },
    {
      "id": "demo-shell",
      "role": "shell",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-shell", "--hold-seconds", "40"],
      "critical": true,
      "launcher": "repo-script"
    },
    {
      "id": "demo-panel",
      "role": "panel",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-panel", "--hold-seconds", "40"],
      "critical": false,
      "launcher": "repo-script"
    },
    {
      "id": "demo-settingsd",
      "role": "settings-daemon",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-settingsd", "--hold-seconds", "40"],
      "critical": false,
      "launcher": "repo-script"
    },
    {
      "id": "demo-status-applet",
      "role": "applet",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-status-applet", "--hold-seconds", "40"],
      "critical": false,
      "launcher": "repo-script"
    }
  ],
  "service_component_bindings": [
    {
      "service": "compd",
      "component_id": "broker-compd"
    }
  ],
  "service_recovery_execution_policies": [
    {
      "service": "compd",
      "mode": "supervisor-restart",
      "restart_command_args": [
        "--restore-from-displayd",
        "--reconcile-waylandd",
        "--handoff-selection",
        "--require-displayd",
        "--require-waylandd"
      ]
    }
  ]
}
