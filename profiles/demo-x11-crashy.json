{
  "id": "demo-x11-crashy",
  "display_name": "Crashy Demo Desktop on LeyerX11",
  "protocol": "layer-x11",
  "summary": "critical component の再起動と crash-loop 判定を確認する demo profile。",
  "degraded_profile_id": "demo-x11-degraded",
  "broker_services": [
    "displayd",
    "sessiond",
    "watchdog",
    "x11bridge"
  ],
  "session_components": [
    {
      "id": "crashy-wm",
      "role": "window-manager",
      "command": ["scripts/mock-desktop-component.sh", "--component", "crashy-wm", "--hold-seconds", "1", "--exit-code", "1"],
      "critical": true,
      "launcher": "repo-script"
    },
    {
      "id": "steady-panel",
      "role": "panel",
      "command": ["scripts/mock-desktop-component.sh", "--component", "steady-panel", "--hold-seconds", "8", "--exit-code", "0"],
      "critical": false,
      "launcher": "repo-script"
    },
    {
      "id": "demo-lockui",
      "role": "lockscreen",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-lockui", "--hold-seconds", "20"],
      "critical": false,
      "launcher": "repo-script"
    }
  ],
  "service_component_bindings": [
    {
      "service": "compd",
      "component_id": "crashy-wm"
    },
    {
      "service": "x11bridge",
      "component_id": "demo-x11bridge"
    },
    {
      "service": "lockd",
      "component_id": "demo-lockui"
    }
  ]
}
