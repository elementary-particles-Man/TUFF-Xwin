{
  "id": "demo-x11-lockd-recovery-optin",
  "display_name": "Demo Desktop on LeyerX11 with Lockd Opt-in",
  "protocol": "layer-x11",
  "summary": "lockd の opt-in recovery execution をテストするための専用 demo profile。",
  "degraded_profile_id": "demo-x11-degraded",
  "broker_services": [
    "displayd",
    "sessiond",
    "watchdog",
    "x11bridge",
    "lockd"
  ],
  "session_components": [
    {
      "id": "demo-x11bridge",
      "role": "compat-layer",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-x11bridge", "--hold-seconds", "20"],
      "critical": true,
      "launcher": "repo-script"
    },
    {
      "id": "demo-wm",
      "role": "window-manager",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-wm", "--hold-seconds", "20"],
      "critical": true,
      "launcher": "repo-script"
    },
    {
      "id": "demo-panel",
      "role": "panel",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-panel", "--hold-seconds", "20"],
      "critical": false,
      "launcher": "repo-script"
    },
    {
      "id": "demo-lockui",
      "role": "lockscreen",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-lockui", "--hold-seconds", "20"],
      "critical": false,
      "launcher": "repo-script"
    }
  ],
  "service_component_bindings": [
    {
      "service": "compd",
      "component_id": "demo-wm"
    },
    {
      "service": "x11bridge",
      "component_id": "demo-x11bridge"
    },
    {
      "service": "lockd",
      "component_id": "demo-lockui"
    }
  ],
  "service_recovery_execution_policies": [
    {
      "service": "lockd",
      "mode": "supervisor-restart"
    }
  ]
}
