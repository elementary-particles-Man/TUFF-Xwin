{
  "id": "demo-x11-lockd-binding-collision",
  "display_name": "Demo Desktop with Lockd Binding Collision",
  "protocol": "layer-x11",
  "summary": "lockd に対して 2 つの binding を持たせ、衝突検出をテストする profile。",
  "broker_services": ["displayd", "sessiond", "watchdog", "x11bridge", "lockd"],
  "session_components": [
    {
      "id": "demo-x11bridge",
      "role": "compat-layer",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-x11bridge", "--hold-seconds", "20"],
      "critical": true,
      "launcher": "repo-script"
    },
    {
      "id": "demo-wm",
      "role": "window-manager",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-wm", "--hold-seconds", "20"],
      "critical": true,
      "launcher": "repo-script"
    },
    {
      "id": "demo-lockui-1",
      "role": "lockscreen",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-lockui-1", "--hold-seconds", "20"],
      "critical": false,
      "launcher": "repo-script"
    },
    {
      "id": "demo-lockui-2",
      "role": "lockscreen",
      "command": ["scripts/mock-desktop-component.sh", "--component", "demo-lockui-2", "--hold-seconds", "20"],
      "critical": false,
      "launcher": "repo-script"
    }
  ],
  "service_component_bindings": [
    {
      "service": "compd",
      "component_id": "demo-wm"
    },
    {
      "service": "x11bridge",
      "component_id": "demo-x11bridge"
    },
    {
      "service": "lockd",
      "component_id": "demo-lockui-1"
    },
    {
      "service": "lockd",
      "component_id": "demo-lockui-2"
    }
  ],
  "service_recovery_execution_policies": [
    {
      "service": "lockd",
      "mode": "supervisor-restart"
    }
  ]
}
